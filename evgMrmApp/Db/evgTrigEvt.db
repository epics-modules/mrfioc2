record(longout, "$(P)TrigSrc-Sel_") {
  field(ASG, "$(ASGPRIVATE=private)")
  field(DTYP, "Obj Prop uint32")
  field(PINI, "RUNNING")
  field(OUT , "@OBJ=$(OBJ), PROP=Source")
  field(VAL , "0x03000000")
  info(autosaveFields_pass0, "VAL")
}

record(longin, "$(P)TrigSrc-RB_") {
  field(ASG, "$(ASGPRIVATE=private)")
  field(DTYP, "Obj Prop uint32")
  field(INP , "@OBJ=$(OBJ), PROP=Source")
  field(SCAN, "I/O Intr")
  field(FLNK, "$(P)TrigSrc-RB")
}

record(stringin, "$(P)TrigSrc-RB") {
  field(DTYP, "LUT uint32 -> string")
  field(INP, "$(P)TrigSrc-RB_")
  info(lut0 , " 0 = Mxc0")
  info(lut1 , " 1 = Mxc1")
  info(lut2 , " 2 = Mxc2")
  info(lut3 , " 3 = Mxc3")
  info(lut4 , " 4 = Mxc4")
  info(lut5 , " 5 = Mxc5")
  info(lut6 , " 6 = Mxc6")
  info(lut7 , " 7 = Mxc7")
  info(lut8 , " 16 = AC")
  info(lut9 , " 0x02010000 = Front0")
  info(luta , " 0x02010001 = Front1")
  info(lutb , " 0x02010002 = Front2")
  info(lutc , " 0x02020000 = Univ0")
  info(lutd , " 0x02020001 = Univ1")
  info(lute , " 0x02020002 = Univ2")
  info(lutf , " 0x02020003 = Univ3")
  info(lutg , " 0x02020004 = Univ4")
  info(luth , " 0x02020005 = Univ5")
  info(luti , " 0x02020006 = Univ6")
  info(lutj , " 0x02020007 = Univ7")
  info(lutk , " 0x02020008 = Univ8")
  info(lutl , " 0x02020009 = Univ9")
  info(lutm , " 0x0202000a = Univ10")
  info(lutn , " 0x0202000b = Univ11")
  info(luto , " 0x0202000c = Univ12")
  info(lutp , " 0x0202000d = Univ13")
  info(lutq , " 0x0202000e = Univ14")
  info(lutr , " 0x0202000f = Univ15")
  info(luts , " 0x02030000 = Rear0")
  info(lutt , " 0x02030001 = Rear1")
  info(lutu , " 0x02030002 = Rear2")
  info(lutv , " 0x02030003 = Rear3")
  info(lutw , " 0x02030004 = Rear4")
  info(lutx , " 0x02030005 = Rear5")
  info(luty , " 0x02030006 = Rear6")
  info(lutz , " 0x02030007 = Rear7")
  info(lutA , " 0x02030008 = Rear8")
  info(lutB , " 0x02030009 = Rear9")
  info(lutC , " 0x0203000a = Rear10")
  info(lutD , " 0x0203000b = Rear11")
  info(lutE , " 0x0203000c = Rear12")
  info(lutF , " 0x0203000d = Rear13")
  info(lutG , " 0x0203000e = Rear14")
  info(lutH , " 0x0203000f = Rear15")
  info(lutI , " 0x02040000 = Back0")
  info(lutJ , " 0x02040001 = Back1")
  info(lutK , " 0x02040002 = Back2")
  info(lutL , " 0x02040003 = Back3")
  info(lutM , " 0x02040004 = Back4")
  info(lutN , " 0x02040005 = Back5")
  info(lutO , " 0x02040006 = Back6")
  info(lutP , " 0x02040007 = Back7")
  info(lutY , " 0x03000000 = Off")
}

record(waveform, "$(P)Label-I") {
  field(DESC, "Label")
  field(FTVL, "CHAR")
  field(NELM, "128")
  info(autosaveFields_pass1, "VAL")
}
